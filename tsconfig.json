{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@/*": ["./entrypoints/manager/*"]
    }
  },
  "include": [
    "entrypoints/**/*.ts",
    "entrypoints/**/*.vue",
    "tests/**/*.ts",
    ".wxt/wxt.d.ts"
  ],
  "exclude": ["node_modules", ".output"]
}
